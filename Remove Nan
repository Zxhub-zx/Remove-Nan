-- โหลด UI Library (Rayfield)
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- สร้าง UI หน้าต่างเล็ก กะทัดรัด เรียบง่ายสุดๆ (Minimal Dark)
local Window = Rayfield:CreateWindow({
   Name = "NaN Anti-Virus",
   LoadingTitle = "Securing Engine...",
   LoadingSubtitle = "Minimalist",
   ConfigurationSaving = { Enabled = false }
})

local MainTab = Window:CreateTab("Shield", 0)

-- ฟังก์ชันเช็คค่า NaN ในระบบระดับลึก
local function isNaN(val)
    if type(val) == "number" then return val ~= val end
    if type(val) == "Vector3" or type(val) == "Vector2" then return val.X ~= val.X end
    return false
end

-- ระบบฮาร์ดคอร์เจาะบล็อกข้อมูล (Metamethod Hook)
local function activateUltimateShield()
    -- สเต็ปที่ 1: สแกนกวาดล้างค่าที่ค้างอยู่ในเครื่อง ณ ปัจจุบันให้เป็น 0 ก่อน
    for _, obj in pairs(game:GetDescendants()) do
        pcall(function()
            if obj:IsA("ValueBase") then
                if isNaN(obj.Value) then
                    obj.Value = 0
                elseif obj:IsA("StringValue") and string.find(string.lower(obj.Value), "nan") then
                    obj.Value = "0"
                end
            end
        end)
    end

    -- สเต็ปที่ 2: ฝังระบบ "ดักฟังและเปลี่ยนค่ากลางอากาศ" (Metamethod Hooking)
    -- วิธีนี้จะดักจับทุกครั้งที่ระบบเกมพยายามจะเขียนค่า (__newindex) ลงในออบเจกต์ 
    -- ถ้าข้อมูลที่เกมจะเปลี่ยนส่งมาเป็น NaN ระบบจะสกัดกั้นและบังคับให้มันกลายเป็น 0 ทันที
    local oldNewIndex
    oldNewIndex = hookmetamethod(game, "__newindex", function(self, property, value)
        -- ตรวจสอบว่าระบบพยายามจะใส่ค่า NaN หรือ ตัวหนังสือคำว่า "NaN" หรือไม่
        if property == "Value" or property == "Text" then
            if isNaN(value) then
                value = 0 -- ถ้าเป็นตัวเลข NaN บังคับเป็น 0 ทันที
            elseif type(value) == "string" and string.find(string.lower(value), "nan") then
                value = "0" -- ถ้าเป็นข้อความ NaN บังคับเป็นตัวอักษร "0"
            end
        end
        return oldNewIndex(self, property, value)
    end)
end

-- UI Elements แบบเรียบง่ายที่สุดตามสั่ง
local StatusText = MainTab:CreateLabel("สถานะ: ระบบเกราะยังไม่ได้เปิดใช้งาน")

MainTab:CreateButton({
   Name = "🛡️ เปิดระบบบล็อก NaN ระดับรากแก้ว (กดครั้งเดียว)",
   Callback = function()
       StatusText:Set("สถานะ: กำลังสับสวิตช์บล็อกเน็ตเวิร์ก...")
       task.wait(0.05)
       
       pcall(activateUltimateShield)
       
       StatusText:Set("สถานะ: เกราะดักจับและบล็อก NaN ทำงานถาวรแล้ว!")
       Rayfield:Notify({
           Name = "System Overridden", 
           Content = "บล็อกการส่งค่า NaN จากเซิร์ฟเวอร์แบบถาวรแล้วในเซิฟนี้", 
           Duration = 4
       })
   end,
})
