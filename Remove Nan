-- โหลด UI Library (Rayfield)
local Rayfield = loadstring(game:HttpGet('https://sirius.menu'))()

local Window = Rayfield:CreateWindow({
   Name = "NaN One-Click Fixer",
   LoadingTitle = "Initializing...",
   LoadingSubtitle = "by AI Assistant",
   ConfigurationSaving = { Enabled = false }
})

-- สร้างแท็บเมนู
local MainTab = Window:CreateTab("Manual Cleaner", 4483362458)

-- ฟังก์ชันเช็คค่า NaN
local function isNaN(value)
    return value ~= value
end

-- ฟังก์ชันจัดการ NaN ในเกมจริง (รันครั้งเดียวตามคำสั่ง)
local function runOnceFix(actionType)
    local fixCount = 0
    local logDetails = ""

    -- สแกนหา NumberValue ทั่วทั้งเกม
    for _, instance in pairs(game:GetDescendants()) do
        pcall(function()
            if instance:IsA("NumberValue") then
                if isNaN(instance.Value) then
                    fixCount = fixCount + 1
                    logDetails = logDetails .. "- " .. instance.Name .. " (" .. instance.Parent.Name .. ")\n"
                    
                    if actionType == "zero" then
                        instance.Value = 0
                    elseif actionType == "delete" then
                        instance:Destroy()
                    end
                end
            end
        end)
    end

    return fixCount, logDetails
end

-- UI Elements
local StatusLabel = MainTab:CreateLabel("สถานะ: พร้อมใช้งาน (กดเพื่อเริ่มทำงานครั้งเดียว)")
local LogLabel = MainTab:CreateLabel("ประวัติ: ยังไม่มีการรันระบบ")

MainTab:CreateButton({
   Name = "🔄 สแกนและเปลี่ยน NaN เป็น 0 (ครั้งเดียว)",
   Callback = function()
       StatusLabel:Set("สถานะ: กำลังสแกนและแก้ไข...")
       task.wait(0.1) -- ให้เวลาระบบเคลียร์ UI แป๊บหนึ่งก่อนเริ่มงานหนัก
       
       local count, logs = runOnceFix("zero")
       
       StatusLabel:Set("สถานะ: เสร็จสิ้น! แก้ไขไป " .. tostring(count) .. " จุด")
       if count > 0 then
           LogLabel:Set("พบและแก้ไขที่:\n" .. logs)
       else
           LogLabel:Set("ประวัติ: ไม่พบค่า NaN ใดๆ ในเกม")
       end
       
       Rayfield:Notify({Name = "สำเร็จ", Content = "เปลี่ยน NaN เป็น 0 จำนวน " .. count .. " จุด", Duration = 4})
   end,
})

MainTab:CreateButton({
   Name = "❌ สแกนและลบ Object ที่เป็น NaN ทิ้ง (ครั้งเดียว)",
   Callback = function()
       StatusLabel:Set("สถานะ: กำลังสแกนและลบ...")
       task.wait(0.1)
       
       local count, logs = runOnceFix("delete")
       
       StatusLabel:Set("สถานะ: เสร็จสิ้น! ลบไป " .. tostring(count) .. " จุด")
       if count > 0 then
           LogLabel:Set("ลบ Object ออกจาก:\n" .. logs)
       else
           LogLabel:Set("ประวัติ: ไม่พบค่า NaN ใดๆ ในเกม")
       end
       
       Rayfield:Notify({Name = "สำเร็จ", Content = "ลบ Object ที่มีค่า NaN ออก " .. count .. " จุด", Duration = 4})
   end,
})
