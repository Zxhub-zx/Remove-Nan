-- [[ CONFIGURATION ]] --
local NOTIFY_TITLE = "NaN Purge Success"
local NOTIFY_TEXT = "🔥 ล้างคำสาป NaN แบบถอนรากถอนโคนสำเร็จแล้ว!"

-- 1. ฟังก์ชันเช็คขยะระดับฮาร์ดแวร์
local function isNaN(val)
    if type(val) == "number" then return val ~= val end
    if type(val) == "Vector3" or type(val) == "Vector2" then return val.X ~= val.X end
    return false
end

-- 2. ระบบดักจับกลางอากาศขั้นโหด (Metamethod Overrider)
local oldNewIndex
oldNewIndex = hookmetamethod(game, "__newindex", function(self, property, value)
    if property == "Value" then
        if isNaN(value) then value = 0 end
    elseif property == "Text" then
        local str = tostring(value):lower()
        if string.find(str, "nan") or string.find(str, "inf") or string.find(str, "ind") then
            value = "0"
        end
    elseif property == "CFrame" or property == "Position" or property == "Size" then
        if isNaN(value) then value = self.CFrame or CFrame.new(0,50,0) end
    elseif property == "Velocity" or property == "AssemblyLinearVelocity" then
        if isNaN(value) then value = Vector3.new(0,0,0) end
    end
    return oldNewIndex(self, property, value)
end)

-- 3. มหกรรมกวาดล้างไฟล์และออบเจกต์ที่ติดบั๊ก ณ ปัจจุบัน
task.spawn(function()
    for _, obj in pairs(game:GetDescendants()) do
        pcall(function()
            -- ซ่อมแซมตระกูลค่าสถานะ/เงิน/คะแนน ทั้งหมด
            if obj:IsA("ValueBase") then
                if isNaN(obj.Value) then
                    obj.Value = 0
                elseif obj:IsA("StringValue") and string.find(obj.Value:lower(), "nan") then
                    obj.Value = "0"
                end
            end
            -- บดขยี้ตัวหนังสือคำว่า NaN บนหน้าจอ UI ทุกชิ้นในเกม
            if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
                local txt = obj.Text:lower()
                if string.find(txt, "nan") or string.find(txt, "inf") or string.find(txt, "ind") then
                    obj.Text = "0"
                end
            end
            -- แก้ไขพิกัดตัวละคร/พาร์ทปลิว
            if obj:IsA("BasePart") then
                if isNaN(obj.CFrame) or isNaN(obj.Position) or isNaN(obj.Velocity) then
                    obj.Velocity = Vector3.new(0, 0, 0)
                    obj.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                end
            end
        end)
    end
end)

-- 4. แสดงข้อความตัวหนังสือแจ้งเตือนระบบทำงานสำเร็จ (ไม่มีหน้าต่าง UI โผล่มา)
pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = NOTIFY_TITLE,
        Text = NOTIFY_TEXT,
        Duration = 6,
        Icon = "rbxassetid://4483362458"
    })
end)
