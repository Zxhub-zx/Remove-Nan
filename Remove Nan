-- โหลด UI Library (Rayfield)
local Rayfield = loadstring(game:HttpGet('https://sirius.menu'))()

local Window = Rayfield:CreateWindow({
   Name = "Universal NaN Shield",
   LoadingTitle = "Securing Game Environment...",
   LoadingSubtitle = "Minimal Dark Edition",
   ConfigurationSaving = { Enabled = false }
})

local MainTab = Window:CreateTab("Shield Menu", 0)

-- ฟังก์ชันเช็คค่า NaN ครอบคลุมทุก Type (Number, Vector, CFrame)
local function isNaN(val)
    if type(val) == "number" then
        return val ~= val
    elseif type(val) == "Vector3" or type(val) == "Vector2" then
        return val.X ~= val.X or val.Y ~= val.Y or (val.X == val.X and val.Y == val.Y and type(val) == "Vector3" and val.Z ~= val.Z)
    elseif type(val) == "CFrame" then
        return val.X ~= val.X or val.Y ~= val.Y or val.Z ~= val.Z
    end
    return false
end

-- ระบบสแกนลึกและฝังเกราะดักจับถาวร
local function applyUniversalShield()
    local securedCount = 0
    
    for _, obj in pairs(game:GetDescendants()) do
        pcall(function()
            -- 1. เคลียร์และล็อกกลุ่ม Value Objects ทั้งหมด (เงิน, ค่าสถานะ, เลเวล, ข้อมูลผู้เล่น)
            if obj:IsA("ValueBase") then
                if isNaN(obj.Value) then
                    if obj:IsA("NumberValue") or obj:IsA("IntValue") then obj.Value = 0
                    elseif obj:IsA("Vector3Value") then obj.Value = Vector3.new(0,0,0)
                    elseif obj:IsA("CFrameValue") then obj.Value = CFrame.new(0,0,0) end
                    securedCount = securedCount + 1
                    
                    -- ดักจับการเปลี่ยนแปลง: ถ้าเซิร์ฟเวอร์ส่ง NaN มาอีก ให้ดีดกลับเป็นค่าปกติทันที
                    obj.Changed:Connect(function(newValue)
                        if isNaN(newValue) then
                            if obj:IsA("NumberValue") or obj:IsA("IntValue") then obj.Value = 0
                            elseif obj:IsA("Vector3Value") then obj.Value = Vector3.new(0,0,0)
                            elseif obj:IsA("CFrameValue") then obj.Value = CFrame.new(0,0,0) end
                        end
                    end)
                -- กรณีระบบเกมแปลงข้อมูลเป็นตัวหนังสือคำว่า "NaN" บนหน้าจอหรือกระดาน
                elseif obj:IsA("StringValue") and string.find(string.lower(obj.Value), "nan") then
                    obj.Value = "0"
                    securedCount = securedCount + 1
                    
                    obj.Changed:Connect(function(newValue)
                        if string.find(string.lower(newValue), "nan") then
                            obj.Value = "0"
                        end
                    end)
                end
            end
            
            -- 2. เคลียร์และล็อกค่าออบเจกต์ทางกายภาพ (โมเดล, กล้อง, ส่วนประกอบที่อาจปลิวเพราะพิกัดพัง)
            if obj:IsA("BasePart") then
                if isNaN(obj.CFrame) or isNaN(obj.Position) or isNaN(obj.Velocity) then
                    obj.Velocity = Vector3.new(0,0,0)
                    obj.RotVelocity = Vector3.new(0,0,0)
                    securedCount = securedCount + 1
                    
                    -- ดักจับกรณีที่แรงเฉื่อยหรือพิกัดโดนแฮกเกอร์ยิงค่า NaN ใส่
                    obj:GetPropertyChangedSignal("Velocity"):Connect(function()
                        if isNaN(obj.Velocity) then obj.Velocity = Vector3.new(0,0,0) end
                    end)
                end
            end
        end)
    end
    return securedCount
end

-- UI หน้าต่างควบคุมแบบเรียบง่ายที่สุด
local DisplayText = MainTab:CreateLabel("สถานะ: รอรันระบบล็อกค่าป้องกันเซิร์ฟเวอร์ป่วน")

MainTab:CreateButton({
   Name = "🛡️ ล้างบั๊กและเปิดเกราะป้องกัน NaN ทุกอย่างในเกม",
   Callback = function()
       DisplayText:Set("กำลังกวาดล้างและวางระบบเกราะดักจับ...")
       task.wait(0.05)
       
       local total = applyUniversalShield()
       
       DisplayText:Set("สำเร็จ! บล็อกและล็อกค่าป้องกันไป " .. tostring(total) .. " จุดทั่วเกม")
       Rayfield:Notify({
           Name = "Universal Shield Active", 
           Content = "ปกป้องค่าทุกอย่างในเครื่องจากการโจมตีด้วย NaN แล้ว!", 
           Duration = 5
       })
   end,
})
