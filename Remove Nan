-- สร้างหน้าต่างแบบเรียบง่าย ขนาดกะทัดรัด (ปิดระบบเซฟและสิ่งรกตา)
local Window = Rayfield:CreateWindow({
   Name = "NaN Deep Cleaner",
   LoadingTitle = "Deep Scanning...",
   LoadingSubtitle = "Minimal Edition",
   ConfigurationSaving = { Enabled = false }
})

local MainTab = Window:CreateTab("Cleaner", 0)

-- ฟังก์ชันเช็คค่า NaN (ตรวจสอบได้ทุก Type ทั้งตัวเลข, Vector, CFrame)
local function isNaN(val)
    if type(val) == "number" then
        return val ~= val
    elseif type(val) == "Vector3" or type(val) == "Vector2" then
        return val.X ~= val.X or val.Y ~= val.Y or (val.X == val.X and val.Y == val.Y and type(val) == "Vector3" and val.Z ~= val.Z)
    elseif type(val) == "CFrame" then
        return val.X ~= val.X or val.Y ~= val.Y or val.Z ~= val.Z
    end
    return false
end

-- ระบบเจาะลึก: ค้นหาและเคลียร์ NaN ทุกรูปแบบใน Instance Properties
local function deepClean(mode)
    local cleared = 0
    
    -- ลุยค้นหาทุก Descendant ทั่วทั้งเกม
    for _, obj in pairs(game:GetDescendants()) do
        pcall(function()
            -- 1. เจาะกลุ่ม Value Objects ทั่วไป
            if obj:IsA("ValueBase") then
                if isNaN(obj.Value) then
                    cleared = cleared + 1
                    if mode == "fix" then
                        if obj:IsA("NumberValue") or obj:IsA("IntValue") then obj.Value = 0
                        elseif obj:IsA("Vector3Value") then obj.Value = Vector3.new(0,0,0)
                        elseif obj:IsA("CFrameValue") then obj.Value = CFrame.new(0,0,0) end
                    else obj:Destroy() end
                end
            end
            
            -- 2. เจาะลึกออบเจกต์กายภาพและพิกัด (Part, Mesh, Camera) ที่มักเกิดบั๊ก NaN จนหลุดโลก
            if obj:IsA("BasePart") or obj:IsA("Camera") then
                if isNaN(obj.CFrame) or isNaN(obj.Position) or isNaN(obj.Size) then
                    cleared = cleared + 1
                    if mode == "fix" then
                        if obj:IsA("BasePart") then
                            obj.CFrame = CFrame.new(0, 50, 0) -- ย้ายกลับมาจุดปลอดภัย
                            obj.Velocity = Vector3.new(0,0,0)
                        end
                    else obj:Destroy() end
                end
            end
            
            -- 3. เจาะระบบเอฟเฟกต์และสี (UI/Lighting) ที่คำนวณพลาดจนกลายเป็นสี NaN (จอมืด/จอกระพริบ)
            if obj:IsA("Color3Value") or obj:IsA("Light") or obj:IsA("UIGradient") then
                if isNaN(obj.Color) then
                    cleared = cleared + 1
                    if mode == "fix" then obj.Color = Color3.new(1,1,1)
                    else obj:Destroy() end
                end
            end
        end)
    end
    return cleared
end

-- หน้าจอแสดงผลแบบมินิมอล
local InfoLabel = MainTab:CreateLabel("ระบบพร้อมเจาะลึกและทำความสะอาดครั้งเดียว")

